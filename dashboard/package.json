{
    "name": "ai-tuber-dashboard",
    "version": "1.0.0",
    "description": "AI Tuber Platform GCP Ops Portal Dashboard",
    "main": "dist/server.js",
    "scripts": {
        "build:client": "cd client && npm run build",
        "build:server": "tsc",
        "build": "npm run build:client && npm run build:server",
        "start": "NODE_ENV=production node dist/server.js",
        "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
        "dev:server": "tsx watch src/server.ts",
        "dev:client": "cd client && npm run dev"
    },
    "dependencies": {
        "@google-cloud/bigquery": "^8.1.1",
        "@google-cloud/billing-budgets": "^6.1.1",
        "@google-cloud/cloudbuild": "^5.0.0",
        "@google-cloud/compute": "^4.0.0",
        "@google-cloud/iam-credentials": "^4.2.1",
        "@google-cloud/run": "^1.0.0",
        "@google-cloud/scheduler": "^4.3.0",
        "@google-cloud/workflows": "^3.0.0",
        "cookie-session": "^2.1.1",
        "express": "^4.21.0",
        "google-auth-library": "^9.15.1"
    },
    "devDependencies": {
        "@types/cookie-session": "^2.0.49",
        "@types/express": "^5.0.0",
        "@types/node": "^22.0.0",
        "concurrently": "^9.2.1",
        "tsx": "^4.0.0",
        "typescript": "^5.7.0"
    }
}
